<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Test Automation Suite" parallel="classes" thread-count="3" verbose="1">
    
    <test name="UI Tests" preserve-order="true">
        <classes>
            <class name="com.tests.ui.LoginUITest"/>
        </classes>
    </test>
    
    <test name="API Tests" preserve-order="true">
        <classes>
            <class name="com.tests.api.UserApiTest"/>
        </classes>
    </test>
    
    <test name="Database Tests" preserve-order="true">
        <classes>
            <class name="com.tests.integration.UserDatabaseTest"/>
        </classes>
    </test>
    
    <test name="End-to-End Integration Tests" preserve-order="true">
        <classes>
            <class name="com.tests.integration.EndToEndIntegrationTest"/>
        </classes>
    </test>
    
</suite>
