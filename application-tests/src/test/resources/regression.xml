<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Regression" parallel="methods" thread-count="12" data-provider-thread-count="6">
    
    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>
    
    <test name="UI Tests">
        <classes>
            <class name="com.automation.tests.ui.LoginTest"/>
            <class name="com.automation.tests.ui.DataDrivenLoginTest"/>
        </classes>
    </test>
    
    <test name="API Tests">
        <classes>
            <class name="com.automation.tests.api.UserApiTest"/>
        </classes>
    </test>
    
    <test name="Database Tests">
        <classes>
            <class name="com.automation.tests.database.UserDatabaseTest"/>
        </classes>
    </test>
    
    <test name="Integration Tests">
        <classes>
            <class name="com.automation.tests.integration.UserEndToEndTest"/>
        </classes>
    </test>

    <test name="BDD Tests">
        <classes>
            <class name="com.automation.tests.bdd.runner.TaggedCucumberRunner"/>
        </classes>
    </test>

</suite>
