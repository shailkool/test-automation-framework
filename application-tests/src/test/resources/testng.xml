<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Test Automation Suite" parallel="tests" thread-count="3">
    
    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>
    
    <!-- UI Tests -->
    <test name="UI Tests" preserve-order="true">
        <classes>
            <class name="com.automation.tests.ui.LoginTest"/>
        </classes>
    </test>
    
    <!-- API Tests -->
    <test name="API Tests" preserve-order="true">
        <classes>
            <class name="com.automation.tests.api.UserApiTest"/>
        </classes>
    </test>
    
    <!-- Database Tests -->
    <test name="Database Tests" preserve-order="true">
        <classes>
            <class name="com.automation.tests.database.UserDatabaseTest"/>
        </classes>
    </test>
    
    <!-- Integration Tests -->
    <test name="Integration Tests" preserve-order="true">
        <classes>
            <class name="com.automation.tests.integration.UserEndToEndTest"/>
        </classes>
    </test>
    
</suite>
