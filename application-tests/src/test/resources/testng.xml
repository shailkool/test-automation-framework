<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Test Automation Suite" parallel="tests" thread-count="3">
    
    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>
    
    <!-- UI Tests -->
    <test name="UI Tests" preserve-order="true">
        <classes>
            <class name="com.automation.tests.ui.LoginTest"/>
        </classes>
    </test>
    
    <!-- API Tests -->
    <test name="API Tests" preserve-order="true">
        <classes>
            <class name="com.automation.tests.api.UserApiTest"/>
        </classes>
    </test>
    
    <!-- Database Tests -->
    <test name="Database Tests" preserve-order="true">
        <classes>
            <class name="com.automation.tests.database.UserDatabaseTest"/>
        </classes>
    </test>
    
    <!-- Integration Tests -->
    <test name="Integration Tests" preserve-order="true">
        <classes>
            <class name="com.automation.tests.integration.UserEndToEndTest"/>
        </classes>
    </test>

    <!-- Environment Configuration Tests -->
    <test name="Environment Configuration Tests" preserve-order="true">
        <classes>
            <class name="com.automation.tests.environment.EnvironmentContextTest"/>
        </classes>
    </test>

    <!-- Run Profile Tests -->
    <test name="Run Profile Tests" preserve-order="true">
        <classes>
            <class name="com.automation.tests.runprofile.RunProfileContextTest"/>
        </classes>
    </test>

    <!--
      Messaging Tests (Kafka + JMS/MQ) require live brokers, so they are not
      registered in the default suite. To run them point Surefire at a
      dedicated suite file, or uncomment the block below.

    <test name="Messaging Tests" preserve-order="true">
        <classes>
            <class name="com.automation.tests.messaging.KafkaMessagingTest"/>
            <class name="com.automation.tests.messaging.JmsMessagingTest"/>
        </classes>
    </test>
    -->

</suite>
