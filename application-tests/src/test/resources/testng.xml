<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Test Automation Suite" parallel="methods" thread-count="12" data-provider-thread-count="6">
    
    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
        <listener class-name="com.smbc.raft.core.retry.FlakeRetryListener"/>
        <listener class-name="com.smbc.raft.core.utils.ShardingListener"/>
    </listeners>
    
    <!-- UI Tests -->
    <test name="UI Tests" preserve-order="true">
        <classes>
            <class name="com.smbc.raft.tests.ui.LoginTest"/>
        </classes>
    </test>
    
    <!-- API Tests -->
    <test name="API Tests" preserve-order="true">
        <classes>
            <class name="com.smbc.raft.tests.api.UserApiTest"/>
        </classes>
    </test>
    
    <!-- Database Tests -->
    <test name="Database Tests" preserve-order="true">
        <classes>
            <class name="com.smbc.raft.tests.database.UserDatabaseTest"/>
        </classes>
    </test>
    
    <!-- Integration Tests -->
    <test name="Integration Tests" preserve-order="true">
        <classes>
            <class name="com.smbc.raft.tests.integration.UserEndToEndTest"/>
        </classes>
    </test>

    <!-- Environment Configuration Tests -->
    <test name="Environment Configuration Tests" preserve-order="true">
        <classes>
            <class name="com.smbc.raft.tests.environment.EnvironmentContextTest"/>
        </classes>
    </test>

    <!-- Run Profile Tests -->
    <test name="Run Profile Tests" preserve-order="true">
        <classes>
            <class name="com.smbc.raft.tests.runprofile.RunProfileContextTest"/>
        </classes>
    </test>

    <!--
      BDD / Cucumber Tests
      Discovers every .feature file under src/test/resources/features and
      executes only scenarios that match the active tag expression. Default
      filter is @smoke (set in TaggedCucumberRunner). Override per-run with
      -Dcucumber.filter.tags="<expression>", e.g.
        -Dcucumber.filter.tags=@multi-site
        -Dcucumber.filter.tags="@navigation and not @wip"
    -->
    <test name="BDD Tests" preserve-order="true">
        <classes>
            <class name="com.smbc.raft.tests.bdd.runner.TaggedCucumberRunner"/>
        </classes>
    </test>

    <!--
      Messaging Tests (Kafka + JMS/MQ) require live brokers, so they are not
      registered in the default suite. To run them point Surefire at a
      dedicated suite file, or uncomment the block below.

    <test name="Messaging Tests" preserve-order="true">
        <classes>
            <class name="com.smbc.raft.tests.messaging.KafkaMessagingTest"/>
            <class name="com.smbc.raft.tests.messaging.JmsMessagingTest"/>
        </classes>
    </test>
    -->

</suite>
